{
  "_comment": "敌人状态机与动画帧映射 — 2D 像素精灵 SpriteSheet 切帧 + 状态转换规则。hframes/vframes 按精灵表统一设置，每个状态的动画为单独 row。",

  "base_mob": {
    "sprite_layout": { "hframes": 4, "vframes": 5 },
    "anims": {
      "idle":    { "row": 0, "start_col": 0, "frames": 4, "fps": 6,  "loop": true },
      "wander":  { "row": 1, "start_col": 0, "frames": 4, "fps": 8,  "loop": true },
      "rest":    { "row": 2, "start_col": 0, "frames": 2, "fps": 3,  "loop": true },
      "aggro":   { "row": 3, "start_col": 0, "frames": 2, "fps": 10, "loop": true },
      "death":   { "row": 4, "start_col": 0, "frames": 4, "fps": 8,  "loop": false }
    },
    "states": {
      "idle":     { "next": "wander",  "after_sec": [3, 8], "anim": "idle" },
      "wander":   { "next": "idle",    "after_sec": [5, 15], "anim": "wander", "speed": 1.1,   "wander_radius": 6.0 },
      "rest":     { "next": "idle",    "after_sec": [10, 25], "anim": "rest",   "chance_from_idle": 0.15 },
      "aggro":    { "next": "chase",   "on_enter": "player_in_range", "anim": "aggro", "range": 3.5 },
      "chase":    { "next": "combat",  "on_contact": true, "anim": "wander", "speed": 2.2 },
      "combat":   { "on": "battle_start", "anim": "idle" },
      "death":    { "on": "hp_zero",   "anim": "death" }
    }
  },

  "forest_beast": {
